{
  "version": 2,
  "name": "campusconnect-bridge",
  "framework": "vite",
  "buildCommand": "cd ../.. && npm install && npm run build && cp -av dist services/api-gateway/dist",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}
